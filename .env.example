# ----------------------------------------------------------------------------
# vyra-backend configuration
# Copy to `.env` and edit. NEVER commit the real .env.
#
# The headline switch is AI_PROVIDER — local (ollama) or cloud (gemini/openai)
# without touching code. `echo` needs no model at all (demo/testing).
# ----------------------------------------------------------------------------

# --- Brain -------------------------------------------------------------------
AI_PROVIDER=ollama            # ollama | gemini | openai | echo

# Ollama — local model on this machine (https://ollama.com)
#   ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Google Gemini (cloud) — key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible (cloud, or LM Studio/Groq/vLLM via OPENAI_BASE_URL)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Generation
LLM_TEMPERATURE=0.9
LLM_TIMEOUT_SECONDS=120
MAX_HISTORY_TURNS=24

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0                  # listen on the LAN so the phone can reach us
PORT=8000
# Optional shared secret. When set: REST needs `X-Vyra-Key` header, the
# websocket needs `?key=`. Leave empty on a trusted home network.
VYRA_API_KEY=

# --- Realtime voice ----------------------------------------------------------
# whisper = transcribe the phone's mic stream on this machine
#           (pip install -r requirements-stt.txt). If unavailable, sessions
#           gracefully fall back to on-device (client) STT.
STT_PROVIDER=whisper          # whisper | client
WHISPER_MODEL=base.en         # tiny.en | base.en | small.en | ...
# cpu is the safe default (base.en int8 transcribes realtime on CPU).
# Only set cuda/auto if your CUDA runtime (cuBLAS/cuDNN) actually works —
# a broken install can make the GPU path HANG, freezing the session.
WHISPER_DEVICE=cpu            # cpu | cuda | auto
WHISPER_COMPUTE_TYPE=int8

# Voice activity detection (tune only if she cuts you off / waits too long)
VAD_END_SILENCE_MS=700        # pause length that ends your turn
VAD_START_MS=100              # sustained voice before it counts as speech
VAD_MIN_RMS=0.010             # absolute voice threshold (0..1 full scale)
BARGE_MIN_MS=300              # how long you must talk over her to interrupt

# --- Companion behaviour -------------------------------------------------------
GREET_ON_CONNECT=true         # she says hi first
GREETING_DELAY_SECONDS=3
PROACTIVE_IDLE_SECONDS=75     # lull length before she re-engages
PROACTIVE_MAX_NUDGES=3        # then she waits for you
SPEAK_TIMEOUT_SECONDS=30
